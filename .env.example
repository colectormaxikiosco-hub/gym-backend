# Servidor
PORT=5000
NODE_ENV=development

# Base de datos
# Opción 1 - Railway/cloud: cadena de conexión (copiar desde el panel de Railway)
DATABASE_URL=mysql://user:password@host:port/database

# Opción 2 - Local: variables por separado
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=gym_db
DB_PORT=3306

# JWT (cambiar JWT_SECRET en producción)
JWT_SECRET=tu_clave_secreta_jwt_muy_segura
JWT_EXPIRE=7d

# CORS - Orígenes permitidos separados por coma (en producción: URL de tu frontend en Vercel)
CORS_ORIGIN=http://localhost:3000

# WhatsApp (Twilio) - opcional
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
